{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Jarvy TOML",
  "scopeName": "source.jarvy-toml",
  "patterns": [
    { "include": "#comment" },
    { "include": "#table" },
    { "include": "#key-value" },
    { "include": "#string" },
    { "include": "#boolean" },
    { "include": "#number" }
  ],
  "repository": {
    "comment": {
      "match": "#.*$",
      "name": "comment.line.number-sign.jarvy-toml"
    },
    "table": {
      "match": "^\\s*(\\[\\[?)\\s*([^\\]]*?)\\s*(\\]\\]?)",
      "captures": {
        "1": { "name": "punctuation.definition.table.jarvy-toml" },
        "2": { "name": "entity.name.section.jarvy-toml" },
        "3": { "name": "punctuation.definition.table.jarvy-toml" }
      }
    },
    "key-value": {
      "match": "^\\s*([A-Za-z0-9_.\"'-]+)\\s*(=)",
      "captures": {
        "1": { "name": "variable.other.key.jarvy-toml" },
        "2": { "name": "keyword.operator.assignment.jarvy-toml" }
      }
    },
    "value": {
      "patterns": [
        { "include": "#string" },
        { "include": "#boolean" },
        { "include": "#number" }
      ]
    },
    "string": {
      "patterns": [
        {
          "name": "string.quoted.double.jarvy-toml",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.jarvy-toml", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.jarvy-toml",
          "begin": "'",
          "end": "'"
        }
      ]
    },
    "boolean": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.jarvy-toml"
    },
    "number": {
      "match": "\\b(0x[0-9A-Fa-f]+|\\d+(\\.\\d+)?)\\b",
      "name": "constant.numeric.jarvy-toml"
    }
  }
}
