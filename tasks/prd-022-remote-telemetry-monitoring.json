  "implementation_notes": {
    "otel_crates": "Use opentelemetry 0.22, opentelemetry-otlp 0.15, opentelemetry_sdk 0.22",
    "semantic_conventions": "Add opentelemetry-semantic-conventions 0.14 for standard attribute names",
    "opt_in": "Telemetry disabled by default until explicitly configured",
    "ci_aware": "Auto-disable when CI=true env var is set, unless JARVY_TELEMETRY=1",
    "privacy": "Redact file paths, env values, usernames from error messages",
    "batching": "Use OTEL SDK default batching settings",
    "module_instrumentation": "Each module gets dedicated event functions in telemetry.rs",
    "metric_labels": "Use consistent label names: tool, pm, command, status, backend, action",
    "cardinality": "Cap label values to known enums, hash unknown tool names"
  },
  "non_goals": [
    "Running our own telemetry backend",
    "Collecting personally identifiable information",
    "Automatic crash reporting",
    "Usage analytics beyond tool operations"
  ],
