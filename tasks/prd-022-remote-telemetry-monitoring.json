  "risks": [
    {
      "description": "OTEL SDK complexity",
      "mitigation": "Follow existing analytics.rs patterns, use standard SDK setup"
    },
    {
      "description": "Breaking change for PostHog users",
      "mitigation": "Provide migration guide, deprecation warning in v1.x"
    },
    {
      "description": "Metric cardinality explosion",
      "mitigation": "Cap tool name labels to known tools, hash unknowns"
    },
    {
      "description": "Performance overhead from instrumentation",
      "mitigation": "Use async exporters, batch by default, sample traces"
    },
    {
      "description": "Code complexity from pervasive instrumentation",
      "mitigation": "Use macros or helper functions for common patterns"
    }
  ],
