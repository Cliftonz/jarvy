{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jarvy.dev/schema/jarvy-telemetry-forwarder.values.schema.json",
  "title": "jarvy-telemetry-forwarder Helm chart values",
  "description": "JSON Schema for the chart's values.yaml. Helm itself validates against this on every `helm install`/`helm upgrade`/`helm template`. Other systems (GitOps webhooks, ArgoCD ApplicationSets, OPA gatekeeper policies, in-house CI) can import this directly to validate inputs before they reach the chart. Source of truth lives at `dist/helm/jarvy-telemetry-forwarder/values.schema.json`; published to https://jarvy.dev/schema/jarvy-telemetry-forwarder.values.schema.json on every chart release.",
  "type": "object",
  "additionalProperties": false,
  "required": ["collector", "exporter", "pii", "secrets", "gatewayApi", "tls", "networkPolicy", "serviceMonitor", "prometheusRule", "pdb", "namespace"],
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "commonLabels": { "type": "object", "additionalProperties": { "type": "string" } },
    "commonAnnotations": { "type": "object", "additionalProperties": { "type": "string" } },

    "collector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "replicas", "resources", "autoscaling", "logLevel", "logFormat", "pipeline", "config", "acceptRawConfigUnsafe"],
      "properties": {
        "image": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository", "pullPolicy"],
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string" },
            "digest": {
              "type": "string",
              "description": "sha256 digest. When set, takes precedence over tag. Required for production supply-chain hygiene.",
              "pattern": "^(|sha256:[a-f0-9]{64})$"
            },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          }
        },
        "replicas": { "type": "integer", "minimum": 1 },
        "podAnnotations": { "type": "object", "additionalProperties": { "type": "string" } },
        "podLabels": { "type": "object", "additionalProperties": { "type": "string" } },
        "resources": {
          "type": "object",
          "properties": {
            "requests": {
              "type": "object",
              "properties": {
                "cpu": { "type": ["string", "number"] },
                "memory": { "type": "string" }
              }
            },
            "limits": {
              "type": "object",
              "properties": {
                "cpu": { "type": ["string", "number"] },
                "memory": { "type": "string" }
              }
            }
          }
        },
        "autoscaling": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "minReplicas", "maxReplicas"],
          "properties": {
            "enabled": { "type": "boolean" },
            "minReplicas": { "type": "integer", "minimum": 1 },
            "maxReplicas": { "type": "integer", "minimum": 1 },
            "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 },
            "targetMemoryUtilizationPercentage": { "type": ["integer", "null"], "minimum": 1, "maximum": 100 },
            "queueDepth": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "metricName": { "type": "string" },
                "averageValue": { "type": ["string", "number"] }
              }
            },
            "behavior": { "type": "object" }
          }
        },
        "topologySpread": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "maxSkew": { "type": "integer" },
            "topologyKey": { "type": "string" },
            "whenUnsatisfiable": { "type": "string", "enum": ["DoNotSchedule", "ScheduleAnyway"] }
          }
        },
        "podSecurityContext": { "type": "object" },
        "containerSecurityContext": { "type": "object" },
        "livenessProbe": { "type": "object" },
        "readinessProbe": { "type": "object" },
        "logLevel": { "type": "string", "enum": ["debug", "info", "warn", "error"] },
        "logFormat": { "type": "string", "enum": ["json", "text", "console"] },
        "pipeline": {
          "type": "object",
          "additionalProperties": false,
          "required": ["memoryLimiter", "batch", "tailSampling"],
          "properties": {
            "memoryLimiter": {
              "type": "object",
              "additionalProperties": false,
              "required": ["limitMib", "spikeLimitMib", "checkInterval"],
              "properties": {
                "limitMib": { "type": "integer", "minimum": 64 },
                "spikeLimitMib": { "type": "integer", "minimum": 16 },
                "checkInterval": { "type": "string" }
              }
            },
            "batch": {
              "type": "object",
              "additionalProperties": false,
              "required": ["timeout", "sendBatchSize", "sendBatchMaxSize"],
              "properties": {
                "timeout": { "type": "string" },
                "sendBatchSize": { "type": "integer", "minimum": 1 },
                "sendBatchMaxSize": { "type": "integer", "minimum": 1 }
              }
            },
            "tailSampling": {
              "type": "object",
              "additionalProperties": false,
              "required": ["numTraces", "decisionWaitSeconds", "probabilisticSamplingPercentage"],
              "properties": {
                "numTraces": { "type": "integer", "minimum": 1 },
                "decisionWaitSeconds": { "type": "integer", "minimum": 1 },
                "probabilisticSamplingPercentage": { "type": "number", "minimum": 0, "maximum": 100 }
              }
            }
          }
        },
        "config": {
          "type": "string",
          "description": "Raw OTel Collector config YAML. When set, replaces the entire pipeline including the anonymize processor. Requires `acceptRawConfigUnsafe: true`."
        },
        "acceptRawConfigUnsafe": { "type": "boolean" },
        "debugExporter": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "verbosity": { "type": "string", "enum": ["basic", "normal", "detailed"] },
            "samplingInitial": { "type": "integer" },
            "samplingThereafter": { "type": "integer" }
          }
        },
        "extraEnv": { "type": "array", "items": { "type": "object" } }
      }
    },

    "exporter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["endpoint", "authScheme"],
      "properties": {
        "endpoint": {
          "type": "string",
          "format": "uri",
          "pattern": "^https?://.+"
        },
        "authScheme": { "type": "string", "enum": ["Basic", "Bearer"] }
      }
    },

    "pii": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passThroughAttributes", "hashedAttributes", "bodyRedactPatterns"],
      "properties": {
        "passThroughAttributes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9._]*$"
          },
          "description": "Allowlist of unhashed attribute keys. Must not overlap with hashedAttributes."
        },
        "hashedAttributes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9._]*$"
          },
          "description": "Keys replaced with salted SHA-256. Must not overlap with passThroughAttributes."
        },
        "bodyRedactPatterns": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["pattern", "replacement"],
            "properties": {
              "pattern": {
                "type": "string",
                "minLength": 1,
                "description": "RE2-compatible regex. Go's regexp does NOT support lookahead/lookbehind."
              },
              "replacement": { "type": "string" }
            }
          }
        }
      }
    },

    "secrets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "grafanaTokenSecretName", "grafanaTokenSecretKey", "piiSaltSecretName", "piiSaltSecretKey"],
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["externalSecrets", "existing", "inline"]
        },
        "grafanaTokenSecretName": { "type": "string", "minLength": 1 },
        "grafanaTokenSecretKey": { "type": "string", "minLength": 1 },
        "piiSaltSecretName": { "type": "string", "minLength": 1 },
        "piiSaltSecretKey": { "type": "string", "minLength": 1 },
        "externalSecrets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "secretStoreRef": {
              "type": "object",
              "required": ["name", "kind"],
              "properties": {
                "name": { "type": "string" },
                "kind": { "type": "string", "enum": ["SecretStore", "ClusterSecretStore"] }
              }
            },
            "refreshInterval": { "type": "string" },
            "grafanaToken": {
              "type": "object",
              "properties": {
                "remoteRef": { "type": "object" }
              }
            },
            "piiSalt": {
              "type": "object",
              "properties": {
                "remoteRef": { "type": "object" }
              }
            }
          }
        },
        "inline": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "grafanaToken": { "type": "string" },
            "piiSalt": { "type": "string" },
            "acceptRisk": { "type": "boolean" }
          }
        }
      }
    },

    "gatewayApi": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "gateway", "httpRoute", "traefikMiddlewares"],
      "properties": {
        "enabled": { "type": "boolean" },
        "gateway": {
          "type": "object",
          "additionalProperties": false,
          "required": ["create", "gatewayClassName"],
          "properties": {
            "create": { "type": "boolean" },
            "gatewayClassName": { "type": "string", "minLength": 1 },
            "annotations": { "type": "object", "additionalProperties": { "type": "string" } },
            "labels": { "type": "object", "additionalProperties": { "type": "string" } },
            "listeners": { "type": "array", "items": { "type": "object" } }
          }
        },
        "httpRoute": {
          "type": "object",
          "additionalProperties": false,
          "required": ["hostnames", "rules"],
          "properties": {
            "annotations": { "type": "object", "additionalProperties": { "type": "string" } },
            "labels": { "type": "object", "additionalProperties": { "type": "string" } },
            "hostnames": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "hostname"
              },
              "minItems": 1
            },
            "parentRefs": { "type": "array", "items": { "type": "object" } },
            "extraFilters": { "type": "array", "items": { "type": "object" } },
            "rules": { "type": "array", "items": { "type": "object" }, "minItems": 1 }
          }
        },
        "traefikMiddlewares": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "rateLimit": {
              "type": "object",
              "properties": {
                "average": { "type": "integer", "minimum": 1 },
                "period": { "type": "string" },
                "burst": { "type": "integer", "minimum": 1 },
                "ipStrategyDepth": { "type": "integer", "minimum": 0 }
              }
            },
            "bodyLimit": {
              "type": "object",
              "properties": {
                "maxRequestBodyBytes": { "type": "integer", "minimum": 1 },
                "memRequestBodyBytes": { "type": "integer", "minimum": 1 }
              }
            }
          }
        }
      }
    },

    "tls": {
      "type": "object",
      "additionalProperties": false,
      "required": ["certManager"],
      "properties": {
        "certManager": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "issuerRef": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "kind": { "type": "string", "enum": ["Issuer", "ClusterIssuer"] }
              }
            }
          }
        },
        "existingSecretName": { "type": "string" }
      }
    },

    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "ingressNamespace": { "type": "string" },
        "monitoringNamespace": { "type": "string" },
        "cilium": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" }
          }
        }
      }
    },

    "serviceMonitor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "labels": { "type": "object", "additionalProperties": { "type": "string" } },
        "interval": { "type": "string" },
        "metricRelabelings": { "type": "array", "items": { "type": "object" } }
      }
    },

    "prometheusRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "labels": { "type": "object", "additionalProperties": { "type": "string" } },
        "alerts": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "refusedRecords": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "for": { "type": "string" }
              }
            },
            "exporterFailing": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "threshold": { "type": "number" },
                "for": { "type": "string" }
              }
            },
            "memoryPressure": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "thresholdBytes": { "type": "integer", "minimum": 1 },
                "for": { "type": "string" }
              }
            },
            "saltStale": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "thresholdDays": { "type": "integer", "minimum": 1 }
              }
            },
            "tailSamplingLow": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "thresholdPercent": { "type": "number", "minimum": 0, "maximum": 1 }
              }
            }
          }
        }
      }
    },

    "pdb": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": ["integer", "string"] }
      }
    },

    "namespace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["create"],
      "properties": {
        "create": { "type": "boolean" },
        "podSecurityStandard": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enforce": { "type": "string", "enum": ["privileged", "baseline", "restricted"] },
            "audit": { "type": "string", "enum": ["privileged", "baseline", "restricted"] },
            "warn": { "type": "string", "enum": ["privileged", "baseline", "restricted"] }
          }
        }
      }
    }
  }
}
