# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# macOS Finder metadata
.DS_Store
**/.DS_Store

# Local agent / mkdocs runtime artifacts
.cache/
.claude/scheduled_tasks.lock

# mkdocs build output
/site/

# Promptfoo eval result files (regenerated each run)
evals/**/results.json
evals/**/smoke-results.json
evals/**/claude-code-results.json
.promptfoo/

# Python bytecode
__pycache__/
*.pyc

# Generated at docs build time from the chart's source-of-truth
# (`dist/helm/jarvy-telemetry-forwarder/values.schema.json`).
# Sync happens in `.github/workflows/docs.yml`. Tracking both in git
# is duplication for no benefit (see maintainability review v2 F3).
docs/schema/jarvy-telemetry-forwarder.values.schema.json

# JetBrains IDE state (RustRover / IntelliJ)
.idea/
.claude/worktrees/
